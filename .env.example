# HCAD environment:
# - local: developer machine
# - sandbox: staging/sandbox deployment with fake or test data
# - production: live production deployment
NEXT_PUBLIC_HCAD_ENV=local

# Backward-compatible environment flag.
# Prefer NEXT_PUBLIC_HCAD_ENV for new deployments.
NEXT_PUBLIC_ENV=local

# Public application URL for links generated by the frontend.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Firebase client configuration.
# Use separate Firebase projects/configs for local, sandbox, and production.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK for server-side repositories and Partner API.
# Use Sandbox credentials only in Sandbox. Never commit real private keys.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Existing server-side integrations.
# Keep these empty in local/sandbox unless intentionally testing the integration.
IJRNY_API_KEY=
WATI_BASE_URL=
WATI_API_TOKEN=
WATI_PAYMENT_TEMPLATE=

# Email settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
OPS_EMAILS=
SALES_EMAILS=

# Optional public email lists used by the transport UI.
NEXT_PUBLIC_OPS_EMAILS=
NEXT_PUBLIC_SALES_EMAILS=

# Server-side canonical app URL.
APP_URL=http://localhost:3000

# Partner API v1 temporary Release 0 authenticator.
# This is replaceable by a future Firestore-backed partners collection.
# Prefer apiKeyHash for real environments. apiKey is only for local/sandbox testing.
# Example:
# HCAD_PARTNER_CREDENTIALS=[{"partnerId":"sandbox-partner","name":"Sandbox Partner","status":"active","apiKey":"sandbox_test_key","scopes":["bookings:create","bookings:read","bookings:status:read","webhooks:test"],"rateLimit":{"limit":60,"windowSeconds":60}}]
HCAD_PARTNER_CREDENTIALS=

# Optional allow-list for webhook test destinations.
# Release 0 simulates delivery only and does not send outbound webhook requests.
HCAD_SANDBOX_WEBHOOK_ALLOWED_HOSTS=
